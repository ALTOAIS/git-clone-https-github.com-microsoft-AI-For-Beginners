DATABASE_URL="postgresql://crh:crh_password@localhost:5432/compliance_risk_hub?schema=public"

JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=3000
CORS_ORIGIN="http://localhost:5173"
UPLOAD_DIR="./uploads"

# --- ИИ-провайдер (Академия комплаенса) ---
# mock (по умолчанию) | openai | anthropic | anthropic-compatible (OpenAI-формат, свой AI_BASE_URL)
AI_PROVIDER="mock"
AI_API_KEY=""
AI_MODEL=""
# Для openai по умолчанию https://api.openai.com/v1, для anthropic — https://api.anthropic.com
AI_BASE_URL=""
AI_TEMPERATURE="0.4"
AI_MAX_TOKENS="4000"
AI_TIMEOUT_MS="60000"
AI_MAX_INPUT_CHARS="24000"
