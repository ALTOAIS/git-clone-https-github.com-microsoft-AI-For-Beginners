// Compliance Risk Hub - Prisma schema
// Data model derived from PRD section 8 (Data Model) and section 6 (Functional Requirements)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// Enums
// ------------------------------------------------------------------

enum Role {
  ADMINISTRATOR
  COMPLIANCE_OFFICER
  COMPLIANCE_MANAGER
  RISK_OWNER
  DEPARTMENT_MANAGER
  INTERNAL_AUDIT
  BOARD
}

/// Risk lifecycle per PRD section 7
enum RiskStatus {
  DRAFT
  NEW
  ASSESSMENT
  APPROVED
  MONITORING
  MITIGATION
  RESIDUAL_ASSESSMENT
  CLOSED
  ARCHIVED
}

/// Направление / бизнес-процесс типового риска в Библиотеке типовых рисков.
/// Отдельно от Category (справочника категорий) — см. RiskTemplate.
enum RiskTemplateDirection {
  PROCUREMENT
  CONTRACT_MANAGEMENT
  CONFLICT_OF_INTEREST
  GIFTS_HOSPITALITY
  HR_PERSONNEL
  FINANCE_PAYMENTS
  ACCOUNTING
  CHARITY_SPONSORSHIP
  GOVERNMENT_INTERACTION
  THIRD_PARTY_DUE_DILIGENCE
  AFFILIATION_RELATED_PARTIES
  ASSET_MANAGEMENT
  CONSTRUCTION_CAPITAL_PROJECTS
  IT_DATA_ACCESS
  INSIDER_INFORMATION
  SANCTIONS
  AML
  FRAUD_THEFT
  CORPORATE_GOVERNANCE
  TRAINING_COMPLIANCE_CULTURE
}

enum SourceType {
  CORRUPTION_RISK_ASSESSMENT
  ANTI_CORRUPTION_MONITORING
  CANDIDATE_DUE_DILIGENCE
  COUNTERPARTY_DUE_DILIGENCE
  INVESTIGATION
  HOTLINE
  CONFLICT_OF_INTEREST
  GIFTS
  AUDIT
  STATE_INSPECTION
  MEDIA
  HR
  PROCUREMENT
  INVESTMENT
  ESG
}

enum ControlType {
  PREVENTIVE
  DETECTIVE
  CORRECTIVE
}

enum ControlEffectiveness {
  EFFECTIVE
  PARTIALLY_EFFECTIVE
  INEFFECTIVE
  NOT_TESTED
}

enum ActionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum IncidentAction {
  CREATE_RISK
  UPDATE_RISK
  CLOSE_RISK
  ESCALATE_RISK
  NONE
}

enum IncidentStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum EntityType {
  RISK
  SOURCE
  CONTROL
  ACTION
  INCIDENT
  COURSE_LESSON
}

enum NotificationType {
  ACTION_DUE_SOON
  ACTION_OVERDUE
  RISK_ASSIGNED
  RISK_STATUS_CHANGED
  INCIDENT_CREATED
  COMMENT_MENTION
  SYSTEM
}

/// The 14-step lifecycle of a Внутренний анализ коррупционных рисков (ВАКР)
enum AnalysisStage {
  CREATION
  PLANNING
  WORKING_GROUP
  DOCUMENTS
  PROCESS_MAP
  FACTORS
  RISKS
  ASSESSMENT
  RECOMMENDATIONS
  ACTION_PLAN
  COORDINATION
  APPROVAL
  MONITORING
  REASSESSMENT
}

enum AnalysisStatus {
  DRAFT
  IN_PROGRESS
  OVERDUE
  COMPLETED
  ARCHIVED
}

enum AnalysisDocumentCategory {
  LAW
  INTERNAL_DOCUMENT
  REGULATION
  PROCEDURE
  POLICY
  INSTRUCTION
  ORG_STRUCTURE
  JOB_DESCRIPTION
  PROCESS_MAP
  PREVIOUS_ANALYSIS
  INSPECTION_MATERIALS
  APPEAL
  COURT_PRACTICE
  OTHER
}

/// Stage 5 "Карта бизнес-процессов" — control-point tags on a process step
enum ProcessControlPointType {
  DECISION_MAKING
  DISCRETIONARY_POWERS
  EXTERNAL_CONTACTS
  FINANCIAL_OPERATIONS
  HR_DECISIONS
  PROCUREMENT
  DIGITAL_SYSTEMS
  CONTROL_MEASURES
}

/// Stage 6 "Выявление коррупциогенных факторов".
/// Дополнено значениями из справочника коррупциогенных факторов по Методическим
/// рекомендациям уполномоченного органа (LEGAL_GAP..EXTERNAL_INTERACTION) —
/// существующие значения сохранены без изменений.
enum CorruptogenicFactorType {
  DISCRETION
  CONFLICT_OF_INTEREST
  LACK_OF_CONTROL
  OPACITY
  EXCEPTIONS
  MANUAL_OPERATIONS
  INFORMATION_ACCESS
  SUPPLIER_CONTACTS
  HR_DECISIONS
  FINANCIAL_OPERATIONS
  PROCUREMENT
  PERMITS
  PROPERTY_USE
  LEGAL_GAP
  LEGAL_COLLISION
  LINGUISTIC_UNCERTAINTY
  RIGHT_INSTEAD_OF_DUTY
  EXCESSIVE_REQUIREMENTS
  ADMINISTRATIVE_BARRIERS
  IMPROPER_FUNCTIONS_DEFINITION
  NO_DEADLINES
  NO_DECISION_GROUNDS
  EXTERNAL_INTERACTION
}

/// Stage 9 "Формирование рекомендаций"
enum RecommendationType {
  ORGANIZATIONAL
  REGULATORY
  HR
  DIGITALIZATION
  AUTOMATION
  STRONGER_CONTROLS
  SEPARATION_OF_DUTIES
  PROCESS_CHANGE
  TRAINING
  MONITORING
}

/// Stage 10 "План мероприятий"
enum ActionPriority {
  LOW
  MEDIUM
  HIGH
}

/// Академия комплаенса — Конструктор курсов
enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonContentType {
  PRESENTATION
  ARTICLE
  INSTRUCTION
  MEMO
  CHECKLIST
  VIDEO
  WEBINAR
  IN_PERSON_EVENT
  EBOOK
  PDF_COURSE
  INTERACTIVE
  PRACTICAL_TASK
  CASE_STUDY
  QUIZ
}

enum CourseAssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

/// Академия комплаенса — Тестирование
enum TestQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

/// Академия комплаенса — Проверка знаний (поэтапные проверки)
enum TestAttemptStage {
  BEFORE
  AFTER
  CHECK_3M
  CHECK_6M
  ANNUAL
}

// ------------------------------------------------------------------
// Organization structure
// ------------------------------------------------------------------

model Company {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments Department[]
  users       User[]
  risks       Risk[]
  analyses    CorruptionAnalysis[]

  @@map("companies")
}

model Department {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processes         BusinessProcess[]
  users             User[]
  risks             Risk[]
  analysisLinks     AnalysisDepartment[]
  planItems         AnalysisPlanItem[]
  processSteps      AnalysisProcessStep[]
  actionItems       AnalysisActionItem[]
  applicableCourses Course[]                  @relation("CourseApplicableDepartments")
  checklistAnswers  AnalysisChecklistAnswer[]
  exposedPositions  AnalysisExposedPosition[]

  @@unique([companyId, name])
  @@map("departments")
}

model BusinessProcess {
  id           String     @id @default(uuid())
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  risks Risk[]

  @@unique([departmentId, name])
  @@map("business_processes")
}

/// Risk Library / risk category catalog (section 5 "Risk Library")
model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryToCategory")
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  risks         Risk[]
  analysisRisks AnalysisRisk[]
  riskTemplates RiskTemplate[]

  @@map("categories")
}

/// Библиотека типовых рисков — каталог шаблонов коррупционных и комплаенс-рисков,
/// НЕ являющийся реестром реальных рисков организации (см. Risk). Из шаблона
/// пользователь создаёт реальный риск в Реестре рисков либо использует его при
/// проведении ВАКР (AnalysisRisk.sourceTemplateId).
model RiskTemplate {
  id         String                @id @default(uuid())
  code       String                @unique
  title      String
  categoryId String?
  category   Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  direction  RiskTemplateDirection

  description        String
  corruptionScheme   String?
  causes             String?
  corruptionFactors  String?
  consequences       String?
  redFlags           String?
  typicalControls    String[]
  recommendedActions String[]

  baseProbability Int // 1-5
  baseImpact      Int // 1-5
  baseScore       Int // baseProbability * baseImpact

  tags     String[]
  isActive Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  risks         Risk[]
  analysisRisks AnalysisRisk[]

  @@map("risk_templates")
}

// ------------------------------------------------------------------
// Users & auth
// ------------------------------------------------------------------

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  fullName     String
  role         Role        @default(RISK_OWNER)
  title        String?
  isActive     Boolean     @default(true)
  companyId    String?
  company      Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  ownedRisks                    Risk[]                       @relation("RiskOwner")
  createdRisks                  Risk[]                       @relation("RiskCreatedBy")
  ownedControls                 Control[]                    @relation("ControlOwner")
  ownedActions                  Action[]                     @relation("ActionOwner")
  reportedIncidents             Incident[]                   @relation("IncidentReportedBy")
  comments                      Comment[]
  attachments                   Attachment[]
  auditLogs                     AuditLog[]
  notifications                 Notification[]
  refreshTokens                 RefreshToken[]
  ledAnalyses                   CorruptionAnalysis[]         @relation("AnalysisLead")
  createdAnalyses               CorruptionAnalysis[]         @relation("AnalysisCreatedBy")
  decidedAnalyses               CorruptionAnalysis[]         @relation("AnalysisDecisionMaker")
  coordinatedAnalyses           CorruptionAnalysis[]         @relation("AnalysisCoordinator")
  updatedChecklistAnswers       AnalysisChecklistAnswer[]    @relation("ChecklistAnswerUpdatedBy")
  analysisMemberships           AnalysisWorkingGroupMember[]
  ownedPlanItems                AnalysisPlanItem[]           @relation("AnalysisPlanItemOwner")
  uploadedAnalysisDocs          AnalysisDocument[]
  executedProcessSteps          AnalysisProcessStep[]        @relation("ProcessStepExecutor")
  ownedAnalysisRisks            AnalysisRisk[]               @relation("AnalysisRiskOwner")
  responsibleForRecommendations AnalysisRecommendation[]     @relation("RecommendationResponsible")
  responsibleForActionItems     AnalysisActionItem[]         @relation("ActionItemResponsible")
  analysisComments              AnalysisComment[]
  createdCourses                Course[]                     @relation("CourseCreatedBy")
  courseAssignments             CourseAssignment[]           @relation("CourseAssignee")
  assignedCourseAssignments     CourseAssignment[]           @relation("CourseAssignedBy")
  testAttempts                  TestAttempt[]                @relation("TestAttemptUser")
  createdSurveys                Survey[]                     @relation("SurveyCreatedBy")
  surveyResponses               SurveyResponse[]             @relation("SurveyRespondent")
  createdCampaigns              Campaign[]                   @relation("CampaignCreatedBy")
  createdTrainingPlans          TrainingPlan[]               @relation("TrainingPlanCreatedBy")
  responsibleTrainingPlanItems  TrainingPlanItem[]           @relation("TrainingPlanItemResponsible")
  certificates                  Certificate[]                @relation("CertificateRecipient")
  aiInteractions                AiInteractionLog[]
  lessonProgress                LessonProgress[]             @relation("LessonProgressUser")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ------------------------------------------------------------------
// Risk sources
// ------------------------------------------------------------------

model Source {
  id              String     @id @default(uuid())
  type            SourceType
  title           String
  description     String?
  referenceNumber String?
  occurredAt      DateTime?
  createdById     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  risks     RiskSource[]
  incidents Incident[]

  @@map("sources")
}

/// Many-to-many: a risk can have any number of sources (PRD section 6 "Sources")
model RiskSource {
  riskId   String
  sourceId String
  risk     Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  source   Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  linkedAt DateTime @default(now())

  @@id([riskId, sourceId])
  @@map("risk_sources")
}

// ------------------------------------------------------------------
// Risk register
// ------------------------------------------------------------------

model Risk {
  id          String     @id @default(uuid())
  code        String     @unique
  title       String
  description String?
  status      RiskStatus @default(DRAFT)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  sourceTemplateId String?
  sourceTemplate   RiskTemplate? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)

  /// Происхождение риска из ВАКР (шаг "Утверждение"/approve()). originContext — снимок
  /// контекста на момент создания (объект/направление анализа, процесс, фактор,
  /// источник информации, причина, последствия, рекомендация) — историческая справка,
  /// не предназначен для реляционных запросов.
  sourceAnalysisId String?
  sourceAnalysis   CorruptionAnalysis? @relation("RiskSourceAnalysis", fields: [sourceAnalysisId], references: [id], onDelete: SetNull)
  originContext    Json?

  companyId         String?
  company           Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  departmentId      String?
  department        Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  businessProcessId String?
  businessProcess   BusinessProcess? @relation(fields: [businessProcessId], references: [id], onDelete: SetNull)

  ownerId     String?
  owner       User?   @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?   @relation("RiskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Inherent assessment
  likelihood    Int? // 1-5
  impact        Int? // 1-5
  inherentScore Int? // likelihood * impact

  // Residual assessment (after controls / mitigation)
  residualLikelihood Int?
  residualImpact     Int?
  residualScore      Int?

  controlEffectivenessAvg Float?

  version    Int       @default(1)
  approvedAt DateTime?
  closedAt   DateTime?
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sources     RiskSource[]
  controls    Control[]
  actions     Action[]
  incidents   Incident[]
  comments    Comment[]
  attachments Attachment[]
  history     RiskHistory[]

  sourceAnalysisRisk AnalysisRisk?

  @@map("risks")
}

/// Versioned change history for a risk (PRD: "История изменений" / "Версионность")
model RiskHistory {
  id          String   @id @default(uuid())
  riskId      String
  risk        Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    Json
  changedById String?
  changeNote  String?
  createdAt   DateTime @default(now())

  @@map("risk_history")
}

// ------------------------------------------------------------------
// Controls
// ------------------------------------------------------------------

model Control {
  id            String               @id @default(uuid())
  riskId        String
  risk          Risk                 @relation(fields: [riskId], references: [id], onDelete: Cascade)
  type          ControlType
  title         String
  description   String?
  ownerId       String?
  owner         User?                @relation("ControlOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  effectiveness ControlEffectiveness @default(NOT_TESTED)
  lastTestedAt  DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("controls")
}

// ------------------------------------------------------------------
// Action plans
// ------------------------------------------------------------------

model Action {
  id                 String       @id @default(uuid())
  riskId             String
  risk               Risk         @relation(fields: [riskId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  ownerId            String?
  owner              User?        @relation("ActionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  deadline           DateTime?
  status             ActionStatus @default(PLANNED)
  evidence           String?
  result             String?
  residualRiskImpact String?
  completedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  sourceActionItem AnalysisActionItem?

  @@map("actions")
}

// ------------------------------------------------------------------
// Incidents
// ------------------------------------------------------------------

model Incident {
  id           String         @id @default(uuid())
  title        String
  description  String?
  occurredAt   DateTime?
  status       IncidentStatus @default(OPEN)
  action       IncidentAction @default(NONE)
  sourceId     String?
  source       Source?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  riskId       String?
  risk         Risk?          @relation(fields: [riskId], references: [id], onDelete: SetNull)
  reportedById String?
  reportedBy   User?          @relation("IncidentReportedBy", fields: [reportedById], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("incidents")
}

// ------------------------------------------------------------------
// Cross-cutting: comments, attachments, audit log, notifications
// ------------------------------------------------------------------

model Comment {
  id        String   @id @default(uuid())
  riskId    String
  risk      Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model Attachment {
  id           String     @id @default(uuid())
  entityType   EntityType
  entityId     String
  riskId       String?
  risk         Risk?      @relation(fields: [riskId], references: [id], onDelete: Cascade)
  fileName     String
  storedName   String
  mimeType     String
  size         Int
  uploadedById String?
  uploadedBy   User?      @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  @@map("attachments")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  changes    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

// ------------------------------------------------------------------
// Внутренний анализ коррупционных рисков (ВАКР)
// ------------------------------------------------------------------

model CorruptionAnalysis {
  id                String         @id @default(uuid())
  code              String         @unique
  name              String
  companyId         String?
  company           Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  subject           String?
  legalBasis        String?
  periodStart       DateTime?
  periodEnd         DateTime?
  deadline          DateTime?
  leadId            String?
  lead              User?          @relation("AnalysisLead", fields: [leadId], references: [id], onDelete: SetNull)
  stage             AnalysisStage  @default(CREATION)
  status            AnalysisStatus @default(DRAFT)
  createdById       String?
  createdBy         User?          @relation("AnalysisCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  completedAt       DateTime?
  reassessmentNotes String?
  reassessedAt      DateTime?

  /// Методологические поля шага "Карточка анализа" (основание/направления ВАКР)
  orderBasis         String?
  orderNumber        String?
  orderDate          DateTime?
  decisionMakerId    String?
  decisionMaker      User?          @relation("AnalysisDecisionMaker", fields: [decisionMakerId], references: [id], onDelete: SetNull)
  analysisScope      AnalysisScope?
  coordinatorId      String?
  coordinator        User?          @relation("AnalysisCoordinator", fields: [coordinatorId], references: [id], onDelete: SetNull)
  extensionRequested Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments      AnalysisDepartment[]
  workingGroup     AnalysisWorkingGroupMember[]
  planItems        AnalysisPlanItem[]
  documents        AnalysisDocument[]
  processSteps     AnalysisProcessStep[]
  factors          AnalysisFactor[]
  risks            AnalysisRisk[]
  recommendations  AnalysisRecommendation[]
  actionItems      AnalysisActionItem[]
  comments         AnalysisComment[]
  checklistAnswers AnalysisChecklistAnswer[]
  exposedPositions AnalysisExposedPosition[]
  createdRisks     Risk[]                       @relation("RiskSourceAnalysis")

  @@map("corruption_analyses")
}

/// Направления анализа ВАКР — шаг "Карточка анализа"
enum AnalysisScope {
  LEGAL_ACTS
  ORG_MANAGEMENT
  BOTH
}

/// Many-to-many: an analysis can cover any number of departments
model AnalysisDepartment {
  id           String             @id @default(uuid())
  analysisId   String
  analysis     CorruptionAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([analysisId, departmentId])
  @@map("analysis_departments")
}

/// Stage 2 "Планирование" — one row per planned process/direction to review
model AnalysisPlanItem {
  id           String             @id @default(uuid())
  analysisId   String
  analysis     CorruptionAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  process      String
  direction    String?
  departmentId String?
  department   Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  ownerId      String?
  owner        User?              @relation("AnalysisPlanItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  deadline     DateTime?
  checkpoint   String?
  createdAt    DateTime           @default(now())

  @@map("analysis_plan_items")
}

/// Stage 3 "Формирование рабочей группы"
model AnalysisWorkingGroupMember {
  id                 String             @id @default(uuid())
  analysisId         String
  analysis           CorruptionAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  role               String
  functions          String?
  responsibilityArea String?
  tasks              String?
  completed          Boolean            @default(false)
  createdAt          DateTime           @default(now())

  @@unique([analysisId, userId])
  @@map("analysis_working_group_members")
}

/// Stage 4 "Сбор документов"
model AnalysisDocument {
  id           String                   @id @default(uuid())
  analysisId   String
  analysis     CorruptionAnalysis       @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  category     AnalysisDocumentCategory
  fileName     String
  storedName   String
  mimeType     String
  size         Int
  uploadedById String?
  uploadedBy   User?                    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime                 @default(now())

  checklistAnswers AnalysisChecklistAnswer[]

  @@map("analysis_documents")
}

/// Stage 5 "Карта бизнес-процессов" — one row per step of the mapped process
model AnalysisProcessStep {
  id                String                    @id @default(uuid())
  analysisId        String
  analysis          CorruptionAnalysis        @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  order             Int
  name              String
  description       String?
  departmentId      String?
  department        Department?               @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  executorId        String?
  executor          User?                     @relation("ProcessStepExecutor", fields: [executorId], references: [id], onDelete: SetNull)
  legalBasis        String?
  inputDescription  String?
  outputDescription String?
  controlPoints     ProcessControlPointType[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  factors AnalysisFactor[]

  @@map("analysis_process_steps")
}

/// Stage 6 "Выявление коррупциогенных факторов" — per process step
model AnalysisFactor {
  id            String                  @id @default(uuid())
  analysisId    String
  analysis      CorruptionAnalysis      @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  processStepId String?
  processStep   AnalysisProcessStep?    @relation(fields: [processStepId], references: [id], onDelete: SetNull)
  factorType    CorruptogenicFactorType
  description   String?
  createdAt     DateTime                @default(now())

  risks            AnalysisRisk[]
  checklistAnswers AnalysisChecklistAnswer[]

  @@map("analysis_factors")
}

/// Stage 7 "Выявление коррупционных рисков" (identification fields) +
/// Stage 8 "Оценка рисков" (likelihood/impact/control effectiveness/residual fields)
model AnalysisRisk {
  id         String             @id @default(uuid())
  analysisId String
  analysis   CorruptionAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  factorId   String?
  factor     AnalysisFactor?    @relation(fields: [factorId], references: [id], onDelete: SetNull)

  title             String
  description       String?
  categoryId        String?
  category          Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sourceTemplateId  String?
  sourceTemplate    RiskTemplate? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  source            String?
  cause             String?
  conditions        String?
  corruptionScheme  String?
  interestedParties String?
  consequences      String?
  existingControls  String?
  ownerId           String?
  owner             User?         @relation("AnalysisRiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  likelihood           Int?
  impact               Int?
  score                Int?
  controlEffectiveness ControlEffectiveness @default(NOT_TESTED)
  residualLikelihood   Int?
  residualImpact       Int?
  residualScore        Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recommendations  AnalysisRecommendation[]
  checklistAnswers AnalysisChecklistAnswer[]
  exposedPositions AnalysisExposedPosition[]

  /// Set when this analysis risk is migrated into the main Risk Register on approval (stage 12)
  linkedRiskId String? @unique
  linkedRisk   Risk?   @relation(fields: [linkedRiskId], references: [id], onDelete: SetNull)

  @@map("analysis_risks")
}

/// Stage 9 "Формирование рекомендаций" — per identified risk
model AnalysisRecommendation {
  id            String             @id @default(uuid())
  analysisId    String
  analysis      CorruptionAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  riskId        String?
  risk          AnalysisRisk?      @relation(fields: [riskId], references: [id], onDelete: SetNull)
  type          RecommendationType
  description   String
  responsibleId String?
  responsible   User?              @relation("RecommendationResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())

  actionItems      AnalysisActionItem[]
  checklistAnswers AnalysisChecklistAnswer[]

  @@map("analysis_recommendations")
}

/// Stage 10 "План мероприятий" — concrete action items, optionally tied to a recommendation
model AnalysisActionItem {
  id               String                  @id @default(uuid())
  analysisId       String
  analysis         CorruptionAnalysis      @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  recommendationId String?
  recommendation   AnalysisRecommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)
  task             String
  expectedResult   String?
  responsibleId    String?
  responsible      User?                   @relation("ActionItemResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  departmentId     String?
  department       Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  deadline         DateTime?
  priority         ActionPriority          @default(MEDIUM)
  status           ActionStatus            @default(PLANNED)
  supportingDocs   String?
  comments         String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  /// Set when this action item is migrated into the main Action Plans module on approval (stage 12)
  linkedActionId String? @unique
  linkedAction   Action? @relation(fields: [linkedActionId], references: [id], onDelete: SetNull)

  @@map("analysis_action_items")
}

/// Stage 11 "Согласование" — discussion thread on the analysis as a whole
model AnalysisComment {
  id         String             @id @default(uuid())
  analysisId String
  analysis   CorruptionAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)
  text       String
  createdAt  DateTime           @default(now())

  @@map("analysis_comments")
}

/// "ВАКР-навигатор" — универсальный ответ на вопрос чек-листа/навигатора,
/// переиспользуется во всех шагах упрощённого ВАКР (карточка анализа, источники
/// информации, вопросы по процессам/факторам, вопросы по рекомендациям).
/// Конкретный набор вопросов (questionKey, текст, допустимые статусы) — статичный
/// справочник на фронтенде, здесь хранится только ответ пользователя.
model AnalysisChecklistAnswer {
  id          String             @id @default(uuid())
  analysisId  String
  analysis    CorruptionAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  questionKey String

  /// Смысл статуса зависит от вопроса: для навигатора — "проверено/не применимо/
  /// требует доработки", для источников информации — "запрошено/получено/не применимо".
  status  String?
  comment String?

  responsibleDepartmentId String?
  responsibleDepartment   Department? @relation(fields: [responsibleDepartmentId], references: [id], onDelete: SetNull)
  dueDate                 DateTime?
  isCurrent               Boolean?
  isReliable              Boolean?

  linkedDocumentId       String?
  linkedDocument         AnalysisDocument?       @relation(fields: [linkedDocumentId], references: [id], onDelete: SetNull)
  linkedFactorId         String?
  linkedFactor           AnalysisFactor?         @relation(fields: [linkedFactorId], references: [id], onDelete: SetNull)
  linkedRiskId           String?
  linkedRisk             AnalysisRisk?           @relation(fields: [linkedRiskId], references: [id], onDelete: SetNull)
  linkedRecommendationId String?
  linkedRecommendation   AnalysisRecommendation? @relation(fields: [linkedRecommendationId], references: [id], onDelete: SetNull)

  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("ChecklistAnswerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([analysisId, questionKey])
  @@map("analysis_checklist_answers")
}

/// Блок "Должности, подверженные коррупционным рискам" — шаг "Процессы, факторы и риски"
model AnalysisExposedPosition {
  id                  String             @id @default(uuid())
  analysisId          String
  analysis            CorruptionAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  positionTitle       String
  departmentId        String?
  department          Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  authorities         String?
  linkedRiskId        String?
  linkedRisk          AnalysisRisk?      @relation(fields: [linkedRiskId], references: [id], onDelete: SetNull)
  riskLevel           String?
  recommendedControls String?
  trainingNeeded      Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("analysis_exposed_positions")
}

// ------------------------------------------------------------------
// Академия комплаенса
// ------------------------------------------------------------------

/// Курс — верхнеуровневая единица обучения, создаваемая в Конструкторе курсов
model Course {
  id              String       @id @default(uuid())
  title           String
  description     String?
  status          CourseStatus @default(DRAFT)
  isMandatory     Boolean      @default(false)
  /// Категории работников (роли), для которых курс обязателен — основа Матрицы обучения.
  /// Пустой список означает «для всех работников».
  applicableRoles Role[]       @default([])
  createdById     String?
  createdBy       User?        @relation("CourseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  modules               CourseModule[]
  assignments           CourseAssignment[]
  test                  Test?
  campaigns             CampaignCourse[]
  /// Подразделения, для которых курс обязателен — второй разрез Матрицы обучения.
  /// Пустой список означает «без ограничения по подразделению».
  applicableDepartments Department[]       @relation("CourseApplicableDepartments")
  planItems             TrainingPlanItem[]
  certificates          Certificate[]

  @@map("courses")
}

/// Модуль курса — группа уроков
model CourseModule {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order    Int
  title    String

  lessons CourseLesson[]

  @@map("course_modules")
}

/// Урок — единица содержания внутри модуля курса
model CourseLesson {
  id              String            @id @default(uuid())
  moduleId        String
  module          CourseModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  order           Int
  title           String
  contentType     LessonContentType
  /// Текст урока в формате Markdown
  content         String?
  /// Ссылка на видео — для уроков типа VIDEO
  videoUrl        String?
  /// Внешняя ссылка (например, ссылка на подключение к вебинару) — для WEBINAR/IN_PERSON_EVENT
  externalUrl     String?
  durationMinutes Int?
  /// Дата и время проведения — для вебинаров и очных мероприятий, отображается в Календаре обучения
  scheduledAt     DateTime?

  progress LessonProgress[]
  /// Тест-урок (quiz) — заполняется только для уроков типа QUIZ
  quiz     Test?

  @@map("course_lessons")
}

/// Назначение курса работнику и его прогресс — минимальная модель для
/// Dashboard Академии и личного кабинета «Моя академия».
/// Автоматическое назначение по событиям в других модулях отложено на следующие фазы.
model CourseAssignment {
  id              String                 @id @default(uuid())
  courseId        String
  course          Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId          String
  user            User                   @relation("CourseAssignee", fields: [userId], references: [id], onDelete: Cascade)
  status          CourseAssignmentStatus @default(NOT_STARTED)
  assignedById    String?
  assignedBy      User?                  @relation("CourseAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  startDate       DateTime?
  dueDate         DateTime?
  progressPercent Int                    @default(0)
  completedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([courseId, userId])
  @@map("course_assignments")
}

/// Отметка о прохождении конкретного урока конкретным работником —
/// основа для автоматического расчёта прогресса и завершения курса.
model LessonProgress {
  id          String       @id @default(uuid())
  lessonId    String
  lesson      CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation("LessonProgressUser", fields: [userId], references: [id], onDelete: Cascade)
  completedAt DateTime     @default(now())

  @@unique([lessonId, userId])
  @@map("lesson_progress")
}

/// Тест — либо итоговый тест курса (courseId), либо тест-урок/quiz (lessonId).
/// Ровно одно из полей courseId/lessonId должно быть заполнено — проверяется на уровне сервиса.
model Test {
  id               String        @id @default(uuid())
  courseId         String?       @unique
  course           Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId         String?       @unique
  lesson           CourseLesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title            String
  passScorePercent Int           @default(70)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  questions TestQuestion[]
  attempts  TestAttempt[]

  @@map("tests")
}

/// Вопрос теста. Поддерживаются 4 типа с автоматической проверкой; сопоставление,
/// установление последовательности, заполнение пропусков и открытые кейс-задания
/// с ручной проверкой отложены на следующую фазу.
model TestQuestion {
  id                String           @id @default(uuid())
  testId            String
  test              Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  order             Int
  type              TestQuestionType
  text              String
  points            Int              @default(1)
  /// Эталонный ответ для SHORT_ANSWER (проверяется без учёта регистра/пробелов)
  correctAnswerText String?

  options TestQuestionOption[]

  @@map("test_questions")
}

/// Вариант ответа — для SINGLE_CHOICE / MULTIPLE_CHOICE / TRUE_FALSE
model TestQuestionOption {
  id         String       @id @default(uuid())
  questionId String
  question   TestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int
  text       String
  isCorrect  Boolean      @default(false)

  @@map("test_question_options")
}

/// Попытка прохождения теста — стадия (BEFORE/AFTER/CHECK_3M/CHECK_6M/ANNUAL)
/// реализует «Проверку знаний» как поэтапные прохождения итогового теста курса.
/// Автоматическое планирование стадий по расписанию отложено на следующую фазу.
/// Для тестов-уроков (quiz) stage всегда NULL — попытки не привязаны к стадии
/// карьерного цикла и допускают повторные попытки до успешного прохождения;
/// Postgres считает каждый NULL уникальным в индексе @@unique ниже, поэтому
/// это преднамеренно снимает ограничение «одна попытка» именно для quiz-уроков,
/// не затрагивая поведение итогового теста курса.
model TestAttempt {
  id           String            @id @default(uuid())
  testId       String
  test         Test              @relation(fields: [testId], references: [id], onDelete: Cascade)
  userId       String
  user         User              @relation("TestAttemptUser", fields: [userId], references: [id], onDelete: Cascade)
  stage        TestAttemptStage?
  scorePercent Int
  passed       Boolean
  /// Присланные ответы { [questionId]: string | string[] } — хранится для истории/аудита
  answers      Json
  submittedAt  DateTime          @default(now())

  @@unique([testId, userId, stage])
  @@map("test_attempts")
}

// ------------------------------------------------------------------
// Опросы
// ------------------------------------------------------------------

enum SurveyStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SurveyQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TEXT
  RATING
}

/// Опрос — сбор мнений без правильных/неправильных ответов (в отличие от Теста)
model Survey {
  id          String       @id @default(uuid())
  title       String
  description String?
  /// Скрывает автора ответа в агрегированных результатах (ответ всё равно связан с пользователем в БД)
  isAnonymous Boolean      @default(false)
  status      SurveyStatus @default(DRAFT)
  createdById String?
  createdBy   User?        @relation("SurveyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  questions SurveyQuestion[]
  responses SurveyResponse[]
  campaigns CampaignSurvey[]

  @@map("surveys")
}

model SurveyQuestion {
  id       String             @id @default(uuid())
  surveyId String
  survey   Survey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  order    Int
  type     SurveyQuestionType
  text     String

  options SurveyQuestionOption[]

  @@map("survey_questions")
}

/// Вариант ответа — для SINGLE_CHOICE / MULTIPLE_CHOICE
model SurveyQuestionOption {
  id         String         @id @default(uuid())
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int
  text       String

  @@map("survey_question_options")
}

model SurveyResponse {
  id          String   @id @default(uuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("SurveyRespondent", fields: [userId], references: [id], onDelete: Cascade)
  /// Ответы { [questionId]: string | string[] | number }
  answers     Json
  submittedAt DateTime @default(now())

  @@unique([surveyId, userId])
  @@map("survey_responses")
}

// ------------------------------------------------------------------
// Комплаенс-кампании
// ------------------------------------------------------------------

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

/// Кампания объединяет уже существующие курсы и опросы в одну инициативу с
/// целевой аудиторией (по ролям). Прогресс участников считается на лету из
/// CourseAssignment/SurveyResponse, отдельная таблица прогресса не заводится.
model Campaign {
  id          String         @id @default(uuid())
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      CampaignStatus @default(DRAFT)
  /// Целевые роли участников. Пустой список означает «все работники».
  targetRoles Role[]         @default([])
  createdById String?
  createdBy   User?          @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  courses CampaignCourse[]
  surveys CampaignSurvey[]

  @@map("campaigns")
}

model CampaignCourse {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([campaignId, courseId])
  @@map("campaign_courses")
}

model CampaignSurvey {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  surveyId   String
  survey     Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([campaignId, surveyId])
  @@map("campaign_surveys")
}

// ------------------------------------------------------------------
// Годовой план обучения
// ------------------------------------------------------------------

enum TrainingPlanStatus {
  DRAFT
  APPROVED
  COMPLETED
}

enum TrainingPlanItemStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

/// Годовой план обучения — один план на календарный год
model TrainingPlan {
  id          String             @id @default(uuid())
  year        Int
  title       String
  status      TrainingPlanStatus @default(DRAFT)
  createdById String?
  createdBy   User?              @relation("TrainingPlanCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  items TrainingPlanItem[]

  @@unique([year])
  @@map("training_plans")
}

/// Строка плана — курс, запланированный на конкретный квартал для целевой аудитории.
/// Статус отслеживается вручную ответственным (по аналогии с планом мероприятий ВАКР);
/// автоматический расчёт прогресса из фактического прохождения отложен на следующую фазу.
model TrainingPlanItem {
  id            String                 @id @default(uuid())
  planId        String
  plan          TrainingPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  courseId      String
  course        Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quarter       Int
  targetRoles   Role[]                 @default([])
  responsibleId String?
  responsible   User?                  @relation("TrainingPlanItemResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  status        TrainingPlanItemStatus @default(PLANNED)
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@map("training_plan_items")
}

// ------------------------------------------------------------------
// Сертификаты
// ------------------------------------------------------------------

/// Сертификат о прохождении курса — выдаётся автоматически при завершении
/// назначения (`CourseAssignment.status = COMPLETED`). Если для курса создан
/// итоговый тест, сертификат выдаётся только при наличии успешной попытки
/// его прохождения; для курсов без теста достаточно самого факта завершения.
model Certificate {
  id                String   @id @default(uuid())
  certificateNumber String   @unique
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation("CertificateRecipient", fields: [userId], references: [id], onDelete: Cascade)
  scorePercent      Int?
  issuedAt          DateTime @default(now())

  @@unique([courseId, userId])
  @@map("certificates")
}

// ------------------------------------------------------------------
// Compliance AI Platform
// ------------------------------------------------------------------

/// Журнал обращений к платформе Compliance AI — фиксирует каждый запрос
/// и ответ ИИ-провайдера для целей контроля и аудита (governance).
/// Не хранит секреты/токены — только сжатую сводку входных данных и результата.
model AiInteractionLog {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role          String?
  module        String
  useCase       String
  provider      String
  /// Идентификатор модели LLM (например gpt-4o-mini); null для mock-провайдера
  model         String?
  /// SUCCESS | ERROR | ERROR_FALLBACK (реальный провайдер упал, ответил mock)
  status        String   @default("SUCCESS")
  errorMessage  String?
  entityType    String?
  entityId      String?
  inputSummary  String
  outputSummary String
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@map("ai_interaction_logs")
}
