# --- База данных ---
# Локально:
DATABASE_URL=postgresql://ef:ef_password@localhost:5432/english_flow?schema=public
# Внешняя managed PostgreSQL (Neon, Supabase, Railway и т.п.) — обычно требует SSL:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# DIRECT_URL нужен, если DATABASE_URL идёт через connection pooler (PgBouncer) —
# именно так у Neon (host с "-pooler"). `prisma migrate deploy` использует
# postgres advisory lock, который не работает через pooled-соединение и
# падает с P1002 по таймауту. DIRECT_URL — тот же адрес БЕЗ pooler'а
# (у Neon: в Connection Details выключите "Pooled connection").
# Если БД без пулера (как локально, или обычный self-hosted Postgres),
# DIRECT_URL можно оставить равным DATABASE_URL.
DIRECT_URL=postgresql://ef:ef_password@localhost:5432/english_flow?schema=public

# --- Сервер ---
PORT=3001
CORS_ORIGIN=http://localhost:5175

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=30d

# --- ИИ-провайдер ---
# AI_PROVIDER: mock | openai | anthropic | anthropic-compatible
# mock (или пустые ключи) = дев-режим: все ответы ИИ помечаются aiMode=fallback
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=
# Для anthropic-compatible / self-hosted endpoints:
AI_BASE_URL=
AI_TEMPERATURE=0.4
# Крупные ответы (диагностика, генератор уроков) требуют запаса токенов,
# иначе JSON обрезается. По умолчанию 4096.
AI_MAX_TOKENS=4096
AI_TIMEOUT_MS=60000

# --- Сиды ---
# SEED_DEMO_USER=true создаст демо-пользователя miras@englishflow.local
SEED_DEMO_USER=false
SEED_DEMO_PASSWORD=english-flow-demo
